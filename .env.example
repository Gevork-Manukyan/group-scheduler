# Appwrite project values
# The server code can reuse these for endpoint + project ID.
NEXT_PUBLIC_APPWRITE_ENDPOINT=
NEXT_PUBLIC_APPWRITE_PROJECT_ID=

# Server-only Appwrite values used by Next.js route handlers.
APPWRITE_API_KEY=
APPWRITE_DATABASE_ID=
APPWRITE_GROUPS_TABLE_ID=
APPWRITE_RESPONSES_TABLE_ID=
